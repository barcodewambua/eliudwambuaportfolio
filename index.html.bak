    <section id="projects" class="container projects py-5">
      <h2 class="h3 mb-4">Selected projects & work experience</h2>
      <div class="row g-4">
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm">
            <img src="assets/projects/project-1.svg" class="card-img-top" alt="Bakery Recipe Predictor" loading="lazy">
            <div class="card-body d-flex flex-column">
              <h5 class="card-title">Bakery Recipe Predictor System (2023)</h5>
              <p class="card-text">AI-powered recipe generator that suggests what to bake based on user-input ingredients using predictive modeling.</p>
              <p class="mt-auto"><small class="text-muted">Tech: Python, Machine Learning</small></p>
            </div>
            <div class="card-footer bg-white border-0">
              <a href="#" class="card-link">Repository</a>
              <a href="#" class="card-link">Demo</a>
            </div>
          </div>
        </div>

        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm">
            <img src="assets/projects/project-2.svg" class="card-img-top" alt="Budget Bite" loading="lazy">
            <div class="card-body d-flex flex-column">
              <h5 class="card-title">Budget Bite — Intelligent Meal Planner (2024)</h5>
              <p class="card-text">Web app that links users with meal options, recipes, and grocery vendors using budget-aware algorithms and merchant integration.</p>
              <p class="mt-auto"><small class="text-muted">Tech: JavaScript, Flask, PostgreSQL</small></p>
            </div>
            <div class="card-footer bg-white border-0">
              <a href="#" class="card-link">Repository</a>
              <a href="#" class="card-link">Live demo</a>
            </div>
          </div>
        </div>

        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm">
            <img src="assets/projects/project-3.svg" class="card-img-top" alt="Vehicle Diagnostic" loading="lazy">
            <div class="card-body d-flex flex-column">
              <h5 class="card-title">Vehicle Diagnostic & Air Quality Monitoring System (2025)</h5>
              <p class="card-text">Real-time environmental tracking system using Arduino sensors and AI analytics for emissions and air quality monitoring.</p>
              <p class="mt-auto"><small class="text-muted">Tech: Arduino, Python, IoT, Machine Learning</small></p>
            </div>
            <div class="card-footer bg-white border-0">
              <a href="#" class="card-link">Repository</a>
              <a href="#" class="card-link">Demo</a>
            </div>
          </div>
        </div>

        <div class="col-12">
          <p class="text-muted small">Want links or screenshots updated? Upload images to `assets/projects/` and provide repo/demo URLs and I'll wire them in.</p>
        </div>
      </div>
    </section>


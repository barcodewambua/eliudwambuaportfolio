    <section id="about" class="container about py-5">
      <div class="row gy-4">
        <div class="col-md-4 text-center">
          <div class="headshot-card mx-auto" style="max-width:200px;">
            <img src="assets/headshot.svg" alt="Eliud Wambua headshot" class="headshot-img" loading="lazy">
          </div>
          <p class="mt-3 mb-0"><a href="#" class="btn btn-outline-primary btn-sm"><img src="assets/linkedin-badge.svg" alt="LinkedIn" style="height:20px;vertical-align:middle;">&nbsp;LinkedIn</a></p>
